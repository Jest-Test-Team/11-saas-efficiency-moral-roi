{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/saas-efficiency-moral-roi/event.schema.json",
  "title": "SaaS Efficiency, Moral ROI Evidence Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenant_id",
    "project",
    "source",
    "observed_at",
    "metric",
    "value",
    "schema_version"
  ],
  "properties": {
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "const": "saas-efficiency-moral-roi"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "ingested_at": {
      "type": "string",
      "format": "date-time"
    },
    "metric": {
      "enum": [
        "value_per_compute_unit",
        "feature_roi",
        "support_burden",
        "security_cost",
        "moral_externality_index"
      ]
    },
    "value": {
      "type": "number"
    },
    "unit": {
      "type": "string"
    },
    "evidence_ref": {
      "type": "string"
    },
    "schema_version": {
      "const": "0.1.0"
    },
    "attributes": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    }
  }
}
